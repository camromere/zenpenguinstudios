@page "/crochet"
@{
    ViewData["Title"] = "Handmade Crochet Patterns";
    ViewData["Description"] = "Crochet pattern PDFs from Zen Penguin Studios — cozy, clearly written, and a little meditative. Coming soon.";
}

@section Head {
    <style>
        .cr-hero {
            background:
                radial-gradient(circle at 50% 0%, rgba(111,90,168,.14), transparent 60%),
                var(--paper);
            text-align: center; padding: 64px 0 24px;
        }
        .cr-hero .yarn { width: 150px; height: 150px; margin-bottom: 8px; }
        .cr-hero h1 { font-size: clamp(2.2rem,5vw,3.2rem); }
        .cr-hero h1 .v { color: var(--violet); }
        .cr-hero p.lede { font-size: 1.15rem; color: var(--muted); max-width: 52ch; margin: 14px auto 0; }

        .pill {
            display:inline-block; margin-top: 22px; padding: 8px 20px; border-radius: 999px;
            background: var(--violet); color:#fff; font-weight:700; font-size:.85rem;
            letter-spacing:.08em; text-transform:uppercase;
        }

        .cr-cards { display:grid; grid-template-columns: repeat(3,1fr); gap:24px; }
        .cr-card { background:#fff; border:1px solid var(--line); border-radius: var(--radius); padding:28px 24px; }
        .cr-card h3 { font-size:1.25rem; color: var(--violet); }
        .cr-card p { color: var(--muted); margin:0; }

        .notify { background: var(--paper-soft); border-top:1px solid var(--line); border-bottom:1px solid var(--line); text-align:center; }
        .notify .wrap { max-width: 640px; }

        @@media (max-width: 820px) { .cr-cards { grid-template-columns: 1fr; } }
    </style>
}

<section class="cr-hero">
    <div class="wrap">
        <svg class="yarn" viewBox="0 0 100 100" aria-hidden="true">
            <circle cx="50" cy="52" r="36" fill="#48a8a8" />
            <path d="M22 38 Q50 28 78 42 M20 50 Q50 42 80 54 M24 62 Q50 56 76 66 M38 20 Q56 50 42 84 M60 19 Q44 52 62 84"
                  fill="none" stroke="#2f7d7d" stroke-width="2.6" stroke-linecap="round" />
            <path d="M76 42 q16 -6 18 -22" fill="none" stroke="#48a8a8" stroke-width="3.6" stroke-linecap="round" />
        </svg>
        <h1>Crochet patterns, <span class="v">coming soon</span></h1>
        <p class="lede">Cozy, clearly written pattern PDFs with charts — the same calm, made-by-hand spirit as our coloring books, in yarn form.</p>
        <span class="pill">In the works</span>
    </div>
</section>

<section>
    <div class="wrap">
        <div class="section-head">
            <h2>What to expect</h2>
            <p>Patterns designed to be genuinely followable — not just pretty pictures.</p>
        </div>
        <div class="cr-cards">
            <div class="cr-card">
                <h3>Clear instructions</h3>
                <p>Step-by-step written directions alongside stitch charts, so you can follow whichever way suits you.</p>
            </div>
            <div class="cr-card">
                <h3>Tested &amp; sized</h3>
                <p>Each pattern worked up and checked, with yarn weights, hook sizes, and finished measurements spelled out.</p>
            </div>
            <div class="cr-card">
                <h3>Instant PDF</h3>
                <p>Delivered as clean, printable PDFs you can keep — available through our shop when they launch.</p>
            </div>
        </div>
    </div>
</section>

<section class="notify">
    <div class="wrap">
        <div class="section-head" style="margin-bottom:0">
            <h2>Want to know when they're ready?</h2>
            <p>Patterns will be released through Etsy and Ravelry. Check back soon — links will land right here.</p>
            <!-- When ready, replace href with your Etsy/Ravelry shop URLs -->
            <a href="#" class="btn btn-violet" style="margin-top:8px;">Shop coming soon</a>
        </div>
    </div>
</section>
